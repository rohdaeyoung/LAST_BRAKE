  m_Script: {fileID: 11500000, guid: 4938916a9d840437b97bab80320d1bbb, type: 3}
  m_Name: BadEnd_Dialogue
  m_EditorClassIdentifier: 
  lines:
  - speaker: "\uB3C4\uC724"
    text: "\uB108... \uC8FD\uC5EC\uBC84\uB9B4 \uAC70\uC57C... \uD5C9, \uD5C9... \uADF8\uB7F0\uB370
      \uBBFC\uC7AC\uC57C... \uB098 \uBAB8\uC774 \uB108\uBB34 \uC774\uC0C1\uD574.
      \uC81C\uBC1C... \uADF8 \uC57D \uD558\uB098\uB9CC \uB354 \uC8FC\uBA74 \uC548
      \uB3FC?"
    portrait: {fileID: 0}
    emotion: 5
    isMonologue: 0
  - speaker: "\uBBFC\uC7AC"
    text: "\uAC70\uBD10, \uACB0\uAD6D \uCC3E\uC744 \uAC70\uBA74\uC11C. \uC790, \uC774\uAC70
      \uBA39\uC73C\uBA74 \uB2E4\uC2DC \uD589\uBCF5\uD574\uC9C8 \uC218 \uC788\uC5B4.
      \uB300\uC2E0 \uACF5\uC9DC\uB294 \uC5C6\uB294 \uAC70 \uC54C\uC9C0?"
    portrait: {fileID: 0}
    emotion: 6
    isMonologue: 0
  - speaker: "\uB3C4\uC724"
    text: "\uC54C\uC558\uC5B4, \uBB50\uB4E0 \uD560\uAC8C. \uC81C\uBC1C... \uC81C\uBC1C
      \uC880 \uC918!"
    portrait: {fileID: 0}
    emotion: 5
    isMonologue: 0
  - speaker: "\uB3C4\uC724"
    text: "\uC57C, \uB108 \uD798\uB4E4\uC9C0? \uC774\uAC70 \uD55C \uC54C\uC774\uBA74
      \uC2A4\uD2B8\uB808\uC2A4 \uC2F9 \uB0A0\uC544\uAC04\uB2E4. \uD55C\uBC88 \uBA39\uC5B4\uBCFC\uB798?"
    portrait: {fileID: 0}
    emotion: 6
    isMonologue: 0
  choices: []
