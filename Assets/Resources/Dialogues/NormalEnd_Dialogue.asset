  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4938916a9d840437b97bab80320d1bbb, type: 3}
  m_Name: NormalEnd_Dialogue
  m_EditorClassIdentifier: 
  lines:
  - speaker: "\uB3C4\uC724"
    text: "\uB9C8\uC57D... \uB0B4\uAC00 \uB9C8\uC57D\uC744 \uD588\uB2E4\uACE0. \uB0B4
      \uC778\uC0DD\uC774 \uC5B4\uB5BB\uAC8C \uC774\uB807\uAC8C \uD55C\uC21C\uAC04\uC5D0..."
    portrait: {fileID: 0}
    emotion: 4
    isMonologue: 0
  - speaker: "\uBBFC\uC7AC"
    text: "\uC815\uC2E0 \uCC28\uB824, \uB3C4\uC724\uC544. \uC774\uBBF8 \uB2A6\uC5C8\uC5B4.
      \uB108\uB3C4 \uC774\uC81C \uACF5\uBC94\uC774\uC57C. \uADF8\uB0E5 \uC870\uC6A9\uD788
      \uC9C0\uB0B4\uC790\uACE0."
    portrait: {fileID: 0}
    emotion: 6
    isMonologue: 0
  - speaker: "\uB3C4\uC724"
    text: "\uC544\uB2C8\uC57C, \uADF8\uB7F4 \uB9AC \uC5C6\uC5B4... \uB2E4 \uC800\uB9AC
      \uAC00! \uB098\uD55C\uD14C \uC5F0\uB77D\uD558\uC9C0 \uB9C8!"
    portrait: {fileID: 0}
    emotion: 4
    isMonologue: 0
  - speaker: "\uC11C\uC544"
    text: "\uB3C4\uC724\uC544! \uC81C\uBC1C \uBB38 \uC880 \uC5F4\uC5B4\uBD10! \uAC19\uC774
      \uBC29\uBC95\uC744 \uCC3E\uC544\uBCF4\uC790!"
    portrait: {fileID: 0}
    emotion: 2
    isMonologue: 0
  - speaker: "\uB3C4\uC724"
    text: "\uB2E4 \uB05D\uB0AC\uC5B4. \uC11C\uC544 \uC5BC\uAD74\uC744 \uC5B4\uB5BB\uAC8C
      \uBD10. \uB2E4 \uB098\uB97C \uC4F0\uB808\uAE30\uCC98\uB7FC \uBCF4\uACA0\uC9C0."
    portrait: {fileID: 0}
    emotion: 5
    isMonologue: 1
  choices: []
