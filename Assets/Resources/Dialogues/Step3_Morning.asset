  m_Script: {fileID: 11500000, guid: 4938916a9d840437b97bab80320d1bbb, type: 3}
  m_Name: Step3_Morning
  m_EditorClassIdentifier: 
  lines:
  - speaker: "\uBBFC\uC7AC(\uCE74\uD1A1)"
    text: "\uB2E4\uB4E4 \uAC71\uC815 \uB9C8\uB77C~ \uD615\uC774 \uC548\uC804\uD558\uAC8C
      \uC9D1 \uCE68\uB300\uAE4C\uC9C0 \uBAA8\uC154\uB2E4\uB4DC\uB9BC. \uB3C4\uC724\uC544,
      \uB108 \uBAB8 \uB9C9 \uB5A8\uB9AC\uB358 \uAC70 \uADF8\uAC70 \uC219\uCDE8 \uC544\uB2C8\uACE0
      \uBAB8\uC0B4 \uAE30\uC6B4 \uC788\uC5B4\uC11C \uADF8\uB7F0 \uAC70\uC57C."
    portrait: {fileID: 0}
    emotion: 6
    isMonologue: 0
  - speaker: "\uBBFC\uC7AC(\uCE74\uD1A1)"
    text: "\uB0B4\uAC00 \uC2DD\uD0C1 \uC704\uC5D0 \uC0C1\uBE44\uC57D \uB194\uB450\uACE0
      \uC654\uAC70\uB4E0. \uADF8\uAC70 \uC13C \uAC70\uB2C8\uAE4C \uD55C \uC54C\uB9CC
      \uB531 \uBA39\uACE0 \uB2E4\uC2DC \uC790\uB77C. \uADF8\uB7FC \uBC14\uB85C \uBA40\uCA61\uD574\uC9C8
      \uAC70\uB2E4."
    portrait: {fileID: 0}
    emotion: 6
    isMonologue: 0
  - speaker: "\uB3C4\uC724"
    text: "...\uC73C\uC73D, \uC9C4\uC9DC \uC8FD\uC744 \uAC83 \uAC19\uC544. \uC774\uAC8C
      \uADF8\uB0E5 \uC220 \uB54C\uBB38\uC774\uB77C\uACE0...?"
    portrait: {fileID: 0}
    emotion: 5
    isMonologue: 1
  - speaker: "\uB3C4\uC724"
    text: "\uC640... \uC9C4\uC9DC \uC0B4 \uAC83 \uAC19\uB2E4. \uC190 \uB5A8\uB9AC\uB294
      \uAC8C \uC21C\uC2DD\uAC04\uC5D0 \uBA48\uCDC4\uB124. \uC5ED\uC2DC \uBBFC\uC7AC
      \uD615\uC774 \uC900 \uC57D\uC774 \uD6A8\uACFC \uD558\uB098\uB294 \uB05D\uB0B4\uC8FC\uB294\uAD6C\uB098.
      \uADF8\uB0E5 \uC2EC\uD55C \uC219\uCDE8\uC600\uB098 \uBD10."
    portrait: {fileID: 0}
    emotion: 1
    isMonologue: 1
  choices:
  - label: "\uC5B4\uC81C \uAE30\uC5B5\uC774 \uD558\uB098\uB3C4 \uC548 \uB098\uC694...
      \uBBFC\uC7AC \uD615 \uC9C4\uC9DC \uAC10\uC0AC\uD569\uB2C8\uB2E4. \uC57D \uBA39\uC73C\uB2C8\uAE4C
      \uBAB8\uC774 \uB0A0\uC544\uAC08 \uAC83 \uAC19\uC544\uC694!"
    intDelta: -5
    riskDelta: 5
    addictDelta: 10
    nextScene: 04_Step4_Party
    isForcedBad: 0
    requiresMinINT: 0
    minINTValue: 0
  - label: "\uD615, \uC774 \uC57D \uC9C4\uC9DC \uB300\uBC15\uC774\uB124\uC694. \uC774\uB984\uC774
      \uBB50\uC608\uC694? \uB098\uC911\uC5D0 \uB610 \uBAB8 \uC548 \uC88B\uC73C\uBA74
      \uC81C\uAC00 \uB530\uB85C \uC0AC \uBA39\uC73C\uB824\uACE0\uC694."
    intDelta: -10
    riskDelta: 10
    addictDelta: 20
    nextScene: 04_Step4_Party
    isForcedBad: 1
    requiresMinINT: 0
    minINTValue: 0
  - label: "\uBBFC\uC7AC \uD615, \uADFC\uB370 \uC774\uAC70 \uADF8\uB0E5 \uC0C1\uBE44\uC57D
      \uB9DE\uC544\uC694? \uBA39\uC790\uB9C8\uC790 \uD1B5\uC99D\uC774 \uC544\uC608
      \uC0AC\uB77C\uC838\uC11C \uC880 \uC2E0\uAE30\uD574\uC11C\uC694."
    intDelta: 15
    riskDelta: 0
    addictDelta: -5
    nextScene: 04_Step4_Party
    isForcedBad: 0
    requiresMinINT: 0
    minINTValue: 0
