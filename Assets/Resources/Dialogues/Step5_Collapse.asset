--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4938916a9d840437b97bab80320d1bbb, type: 3}
  m_Name: Step5_Collapse
  m_EditorClassIdentifier: 
  lines:
  - speaker: "\uBBFC\uC7AC"
    text: "\uB3C4\uC724\uC544, \uC624\uB298 \uCD95\uC81C \uD53C\uB0A0\uB808\uB2E4.
      \uC774\uAC70 \uC5B4\uC81C \uADF8 \uC57D \uAC15\uD654 \uBC84\uC804\uC774\uC57C.
      \uC624\uB298 \uC774\uAC70\uBA74 \uB10C \uC9C4\uC9DC \uC2E0\uC774 \uB41C \uAE30\uBD84\uC77C\uAC78?"
    portrait: {fileID: 0}
    emotion: 6
    isMonologue: 0
  - speaker: "\uC11C\uC544"
    text: "\uBC15\uBBFC\uC7AC \uC624\uBE60, \uADF8\uB9CC\uD574! \uB3C4\uC724\uC544,
      \uB108 \uC800\uAC70 \uBA39\uC73C\uBA74 \uC9C4\uC9DC \uB05D\uC774\uC57C. \uC81C\uBC1C
      \uB098\uB791 \uAC19\uC774 \uB098\uAC00\uC790, \uC751?"
    portrait: {fileID: 0}
    emotion: 2
    isMonologue: 0
  - speaker: "\uB3C4\uC724"
    text: "\uC544, \uC9C4\uC9DC... \uBD84\uC704\uAE30 \uB2E4 \uB9DD\uCE58\uB124!
      \uBBFC\uC7AC \uD615\uC774 \uB098 \uC0DD\uAC01\uD574\uC11C \uC900 \uAC74\uB370
      \uB124\uAC00 \uC65C \uB09C\uB9AC\uC57C? \uD615, \uC918\uC694. \uB0B4\uAC00
      \uB2E4 \uB9C8\uC154\uBC84\uB9B4 \uAC70\uB2C8\uAE4C."
    portrait: {fileID: 0}
    emotion: 3
    isMonologue: 0
  - speaker: "\uB3C4\uC724"
    text: "\uC73C... \uC73C\uC73D... \uC544\uC545! \uBAB8\uC774... \uB204\uAC00 \uC804\uAE30\uB85C
      \uC9C0\uC9C0\uB294 \uAC83 \uAC19\uC544... \uBBFC\uC7AC... \uBBFC\uC7AC \uD615...
      \uC57D... \uC81C\uBC1C..."
    portrait: {fileID: 0}
    emotion: 5
    isMonologue: 0
  - speaker: "\uBBFC\uC7AC"
    text: "\uC640, \uC6B0\uB9AC \uB3C4\uC724\uC774 \uC57D\uBE68 \uBC1B\uB294 \uC18D\uB3C4\uAC00
      \uAC70\uC758 \uC608\uC220\uC778\uB370. \uBC8C\uC368\uBD80\uD130 \uC774\uB807\uAC8C
      \uC774\uB807\uAC8C\uAE4C\uC9C0 \uAE30\uC5B4\uC640\uC11C \uCC3E\uC73C\uBA74 \uC5B4\uB5A1\uD558\uB0D0.
      \uC774\uAC70 \uC544\uBB34\uB098 \uBABB \uAD6C\uD558\uB294 \uADC0\uD55C \uAC70\uC57C."
    portrait: {fileID: 0}
    emotion: 6
    isMonologue: 0
  - speaker: "\uBBFC\uC7AC"
    text: "\uB9DD\uCE58\uAE34 \uB204\uAC00 \uB9DD\uCCD0. \uC120\uD0DD\uC740 \uB124\uAC00
      \uD588\uC9C0. \uC774\uC81C \uACB0\uC815\uD574. \uB098\uB791 \uAC19\uC774 \uBE44\uC988\uB2C8\uC2A4
      \uD558\uBA74\uC11C \uC774 \uAE30\uBD84 \uC720\uC9C0\uD560\uB798? \uC544\uB2C8\uBA74
      \uC5EC\uAE30\uC11C \uB0B4\uAC00 \uB2E4 \uB108 \uC8FC\uBCC0\uC0AC\uB78C\uB4E4\uD55C\uD14C
      \uB2E4 \uB9D0\uD558\uACE0 \uD63C\uC790 \uC628\uBAB8\uC774 \uB4A4\uD2C0\uB824
      \uC8FD\uC744\uB798?"
    portrait: {fileID: 0}
    emotion: 6
    isMonologue: 0
  choices:
  - label: "\uC9C0\uC625\uC5D0 \uAC08 \uAC70\uBA74 \uB108\uB791 \uAC19\uC774 \uAC00\uC904\uAC8C.
      \uB2F9\uC7A5 \uACBD\uCC30\uC5D0 \uC2E0\uACE0\uD55C\uB2E4."
    intDelta: 25
    riskDelta: -20
    addictDelta: -20
    nextScene: 
    isForcedBad: 0
    requiresMinINT: 1
    minINTValue: 70
  - label: "\uB098 \uAC19\uC740 \uB188\uC774 \uBB34\uC2A8... \uB2E4 \uB05D\uB0AC\uC5B4.
      \uADF8\uB0E5 \uC544\uBB34\uB3C4 \uB098 \uCC3E\uC9C0 \uBABB\uD558\uAC8C \uD574\uC918..."
    intDelta: -15
    riskDelta: 10
    addictDelta: 5
    nextScene: 
    isForcedBad: 0
    requiresMinINT: 0
    minINTValue: 0
  - label: "\uC54C\uC558\uC5B4... \uD615 \uC2DC\uD0A4\uB294 \uAC70 \uB2E4 \uD560\uAC8C.
      \uADF8\uB7EC\uB2C8\uAE4C \uC81C\uBC1C \uADF8\uAC70 \uD55C \uC54C\uB9CC... \uD55C
      \uC54C\uB9CC \uC918."
    intDelta: -25
    riskDelta: 20
    addictDelta: 30
    nextScene: 
    isForcedBad: 1
    requiresMinINT: 0
    minINTValue: 0
