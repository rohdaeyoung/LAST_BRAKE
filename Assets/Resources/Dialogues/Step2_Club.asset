  m_Script: {fileID: 11500000, guid: 4938916a9d840437b97bab80320d1bbb, type: 3}
  m_Name: Step2_Club
  m_EditorClassIdentifier: 
  lines:
  - speaker: "\uBBFC\uC7AC"
    text: "\uB3C4\uC724\uC544, \uC774\uAC70 \uC6D0\uC0F7\uD574\uBD10. \uC774\uAC8C
      \uC5EC\uAE30 \uC2DC\uADF8\uB2C8\uCC98\uAC70\uB4E0. \uD55C \uBC29\uC5D0 \uC815\uC2E0\uC774
      \uBC88\uCA4D \uB4E4 \uAC70\uB2E4."
    portrait: {fileID: 0}
    emotion: 6
    isMonologue: 0
  - speaker: "\uB3C4\uC724"
    text: "\uAC11\uC790\uAE30 \uC65C \uC774\uB7EC\uC9C0? \uC2EC\uC7A5\uC774 \uAC08\uBE44\uBF08\uB97C
      \uB6AB\uACE0 \uB098\uC62C \uAC83 \uAC19\uC544. \uC190\uB05D\uC774 \uC804\uAE30\uC5D0
      \uAC10\uC804\uB41C \uAC83\uCC98\uB7FC \uB35C\uB35C \uB5A8\uB9AC\uB294\uB370...
      \uADFC\uB370 \uAE30\uBD84\uC740 \uC65C \uC774\uB807\uAC8C \uC88B\uC544\uC9C0\uB294
      \uAC70\uC9C0?"
    portrait: {fileID: 0}
    emotion: 4
    isMonologue: 1
  - speaker: "\uC11C\uC544"
    text: "\uAC15\uB3C4\uC724! \uB108 \uC815\uC2E0 \uCC28\uB824\uBD10! \uB108 \uC9C0\uAE08
      \uC2DD\uC740\uB540 \uC7A5\uB09C \uC544\uB2C8\uC57C. \uB208\uB3C4 \uC644\uC804\uD788
      \uD480\uB838\uC5B4! \uBBFC\uC7AC \uC624\uBE60, \uB3C4\uC724\uC774\uD55C\uD14C
      \uBB50 \uBA39\uC778 \uAC70\uC57C?"
    portrait: {fileID: 0}
    emotion: 2
    isMonologue: 0
  - speaker: "\uBBFC\uC7AC"
    text: "\uC544, \uC11C\uC544 \uC880! \uC560 \uC9C0\uAE08 \uAE30\uBD84 \uCD5C\uACE0\uC870\uC778\uB370
      \uC65C \uCC2C\uBB3C\uC744 \uB07C\uC5B9\uACE0 \uADF8\uB798. \uB3C4\uC724\uC544,
      \uC9C0\uAE08 \uAE30\uBD84 \uCD5C\uACE0\uC9C0? \uADF8\uB0E5 \uC774 \uB9AC\uB4EC\uC5D0 \uBAB8\uC744
      \uB9E1\uACA8\uBD10!"
    portrait: {fileID: 0}
    emotion: 6
    isMonologue: 0
  choices:
  - label: "\uBBFC\uC7AC\uC57C, \uB098 \uC9C4\uC9DC \uC774\uC0C1\uD574. \uC77C\uB2E8
      \uD654\uC7A5\uC2E4 \uAC00\uC11C \uC138\uC218 \uC880 \uD558\uACE0 \uC62C\uAC8C."
    intDelta: 15
    riskDelta: -5
    addictDelta: 0
    nextScene: 03_Step3_Morning
    isForcedBad: 0
    requiresMinINT: 0
    minINTValue: 0
  - label: "\uC544, \uAC11\uC790\uAE30 \uC65C \uC774\uB7EC\uC9C0? \uD558\uC900\uC544,
      \uB108\uB3C4 \uADF8\uB798? \uB098\uB9CC \uC720\uB09C \uB5A0\uB294 \uAC70 \uC544\uB2C8\uC9C0?"
    intDelta: 0
    riskDelta: 0
    addictDelta: 5
    nextScene: 03_Step3_Morning
    isForcedBad: 0
    requiresMinINT: 0
    minINTValue: 0
  - label: "\uB300\uBC15... \uC57C, \uC774\uAC70 \uBB50\uC57C? \uC138\uC0C1\uC774
      \uB9C9 \uB3CC\uC544\uAC00\uB294\uB370 \uAE30\uBD84 \uC815\uB9D0 \uC774\uC0C1\uD574.
      \uD55C \uC794 \uB354 \uC5C6\uC5B4?"
    intDelta: -20
    riskDelta: 10
    addictDelta: 20
    nextScene: 03_Step3_Morning
    isForcedBad: 1
    requiresMinINT: 0
    minINTValue: 0
